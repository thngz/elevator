	<template>
		<name>FloorPanel</name>
		<parameter>const f_id id</parameter>
		<declaration>void setFloorCallToUp(f_id id) {
    floorCall.floor_called_from = id;
    floorCall.direction = 1;
}

void setFloorCallToDown(f_id id) {
    floorCall.floor_called_from = id;
    floorCall.direction = -1;
}

bool sentUp = false;

void sendUpOrDown(bool sentUp) {
    if (sentUp) {
        setFloorCallToDown(id);
    } else {
        setFloorCallToUp(id);
    }
}</declaration>
