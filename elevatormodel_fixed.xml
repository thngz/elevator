	<template>
		<name>ServiceQueue</name>
		<declaration>typedef struct {
    int floorNumber;
    Direction direction;
    bool isElevatorCall;
} Request;
const int MAX_QUEUE = 10;
Request queue[MAX_QUEUE];


void appendElevatorRequest(GotoFloor&amp; g) {
    if (queueSize &gt;= MAX_QUEUE ) {return;}
    queue[queueSize].floorNumber = g.selected_floor;
    queue[queueSize].direction = 0;
    queue[queueSize].isElevatorCall = true;
    queueSize++;
}

void appendFloorRequest(FloorCall&amp; f) {
    if (queueSize &gt;= MAX_QUEUE ) {return;}
    queue[queueSize].floorNumber = f.floor_called_from;
    queue[queueSize].direction = f.direction;
    queue[queueSize].isElevatorCall = false;
    queueSize++;
}

void processQueue() {
    int best = 0;
    int i;
    int bestDist;
    int dist;

    if (currentDirection == 0) {
        // idle- pick closest floor
        bestDist = 999;
        for (i = 0; i &lt; queueSize; i++) {
            dist = queue[i].floorNumber - current_floor;
            if (dist &lt; 0) { dist = -dist; }
            if (dist &lt; bestDist) {
                bestDist = dist;
                best = i;
            }
        }
    } else {

        for (i = 0; i &lt; queueSize; i++) {
            if (currentDirection == 1 &amp;&amp; queue[i].floorNumber &gt; current_floor) {
                best = i;
            }
            if (currentDirection == -1 &amp;&amp; queue[i].floorNumber &lt; current_floor) {
                best = i;
            }
        }
    }

    target_floor = queue[best].floorNumber;
    if (target_floor &gt; current_floor)      target_direction = 1;
    else if (target_floor &lt; current_floor) target_direction = -1;
    else                                    target_direction = 0;

    currentDirection = target_direction;

    for (i = best; i &lt; queueSize - 1; i++) {
        queue[i] = queue[i + 1];
    }
    queueSize--;
}</declaration>
