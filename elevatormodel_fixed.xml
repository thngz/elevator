	<template>
		<name>ElevatorManager</name>
		<declaration>clock travelTimer;

void updateDisplay() {
    floorDisplay[current_floor].display_floor = current_floor;
    floorDisplay[current_floor].direction = currentDirection;
    elevatorDisplay.display_floor = current_floor;
    elevatorDisplay.direction = currentDirection;
}

int queueSize = 0;
const int MAX_QUEUE = 200;
int queue[MAX_QUEUE]; // this keeps in memory the requests to elevator

void sortQueue(bool ascending) {
    int i, j, tmp; 
    for (i = 0; i &lt; queueSize - 1; i++) {
        for (j = 0; j &lt; queueSize - i - 1; j++) {
            bool shouldSwap = ascending ? queue[j] &gt; queue[j+1] : queue[j] &lt; queue[j+1];
            if (shouldSwap) {
                tmp = queue[j];
                queue[j] = queue[j+1];
                queue[j+1] = tmp;
            }
        }
    }
}

void shiftQueue(int i) {
    int j;
    for (j = i; j &lt; queueSize - 1; j++) {
        queue[j] = queue[j+1];
    }
    queueSize--;
}

void appendFloorCall(int targetFloor) {
    if (queueSize &gt;= MAX_QUEUE) { return; }
    queue[queueSize] = targetFloor;
    queueSize++;
}

void processQueue() {
    int i = 0;
    bool found;
    int attempt;
    if (queueSize == 0) { return; }

    found = false;


    for (attempt = 0; attempt &lt; 2 &amp;&amp; !found; attempt++) {
        sortQueue(currentDirection &gt;= 0);

        while (i &lt; queueSize &amp;&amp; !found) {
            if ((currentDirection &gt;= 0 &amp;&amp; queue[i] &gt;= current_floor) ||
                (currentDirection == -1 &amp;&amp; queue[i] &lt;= current_floor)) {

                targetFloor = queue[i];

                if (targetFloor &gt; current_floor)      currentDirection = 1;
                else if (targetFloor &lt; current_floor) currentDirection = -1;
                else                                  currentDirection = 0;

                found = true;
            }
            i++;
        }

        if (!found) {
            currentDirection = -currentDirection;
            if (currentDirection == 0) currentDirection = 1;
        }
    }
}

void removeReachedFloor() {
    int i = 0;
    while (i &lt; queueSize) {
        if (queue[i] == current_floor) { shiftQueue(i); }
        else { i++; }
    }
}</declaration>
