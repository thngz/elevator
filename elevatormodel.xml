chan floorCall;
chan elevatorCall;</declaration>
	<template>
		<name>ServiceQueue</name>
		<declaration>typedef struct {
    int floorNumber;
    Direction direction;
    bool isElevatorCall;
} Request;

Request queue[10]; // Assuming a maximum of 10 requests
int queueSize = 0;
bool elevatorBusy = false;

void appendElevatorRequest(ElevatorCallMessage&amp; eCallMsg) {

    queue[queueSize].floorNumber = eCallMsg.selected_floor;
	queue[queueSize].direction = 0; // Default direction for elevator calls
	queue[queueSize].isElevatorCall = true;
	queueSize++;
}

void appendFloorRequest(FloorCallMessage&amp; fCallMsg) {

    queue[queueSize].floorNumber = fCallMsg.floor_called_from;
    queue[queueSize].direction = fCallMsg.direction;
    queue[queueSize].isElevatorCall = false;
    queueSize++;
}</declaration>
