	<template>
		<name>ServiceQueue</name>
		<declaration>typedef struct {
    int floorNumber;
    Direction direction;
    bool isElevatorCall;
} Request;

Request queue[10]; // Assuming a maximum of 10 requests
int queueSize = 0;
bool elevatorBusy = false;

void appendElevatorRequest(GotoFloor&amp; g) {

    queue[queueSize].floorNumber = g.selected_floor;
	queue[queueSize].direction = 0; // Default direction for elevator calls
	queue[queueSize].isElevatorCall = true;
	queueSize++;
}

void appendFloorRequest(FloorCall&amp; f) {

    queue[queueSize].floorNumber = f.floor_called_from;
    queue[queueSize].direction = f.direction;
    queue[queueSize].isElevatorCall = false;
    queueSize++;
}


void processQueue() {
    int best = 0;
    int i;
    // 1) Look for a request in-direction and ahead
    for (i = 0; i &lt; queueSize; i++) {
        if (currentDirection == 1
            &amp;&amp; queue[i].floorNumber &gt; current_floor) {
            best = i; 
        }
        if (currentDirection == -1
            &amp;&amp; queue[i].floorNumber &lt; current_floor) {
            best = i;
        }
    }
    // 2) Set globals from chosen entry
    target_floor = queue[best].floorNumber;
    if (target_floor &gt; current_floor)      target_direction = 1;
    else if (target_floor &lt; current_floor) target_direction = -1;
    else                                    target_direction = 0;

    // 3) Remove chosen entry (shift left)
    for (i = best; i &lt; queueSize - 1; i++) {
        queue[i] = queue[i + 1];
    }
    queueSize--;
}</declaration>
